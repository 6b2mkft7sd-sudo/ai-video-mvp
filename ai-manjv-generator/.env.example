# 可选：如果 AI_PROVIDER=openai，填 OpenAI API Key。
OPENAI_API_KEY=

# 默认使用国内更容易访问的通义千问 DashScope。
DASHSCOPE_API_KEY=
AI_PROVIDER=dashscope

# DashScope 官方 HTTP endpoint。
DASHSCOPE_ENDPOINT=https://dashscope.aliyuncs.com/api/v1/services/aigc/text-generation/generation

# 通义万相 Wanx 图片生成。默认复用 DASHSCOPE_API_KEY，也可以单独填写 WANX_API_KEY。
WANX_API_KEY=
WANX_ENDPOINT=https://dashscope.aliyuncs.com/api/v1/services/aigc/text2image/image-synthesis
WANX_TASK_ENDPOINT=https://dashscope.aliyuncs.com/api/v1/tasks
WANX_MODEL=wanx-v1
WANX_SIZE=720*1280

# 只有 AI_PROVIDER=openai 时才使用这个配置。
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=qwen-plus

# 本地启动端口。
PORT=3000
